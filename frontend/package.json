{
  "name": "easymeeting-frontend",
  "private": true,
  "version": "1.0.0",
  "description": "EasyMeeting 会议管理系统",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "chcp 65001 >nul 2>&1 && set NODE_ENV=development && electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:dist": "npm run build && electron-builder --win --mac --linux"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "element-plus": "^2.13.2",
    "vue": "^3.3.4",
    "vue-router": "^4.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.2.3",
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0",
    "terser": "^5.44.1",
    "vite": "^4.4.5"
  },
  "build": {
    "appId": "com.easymeeting.app",
    "productName": "EasyMeeting",
    "copyright": "Copyright © 2026 EasyMeeting",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/vite.svg"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/vite.svg"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "icon": "public/vite.svg"
    }
  }
}
